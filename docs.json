{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Aasure",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/logo/favicon.svg",
  "colors": {
    "primary": "#2E8A52",
    "light": "#59A87B",
    "dark": "#1A6338"
  },
  "topbarLinks": [
    { "name": "Sign in", "url": "https://biz.aasure.app" }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://biz.aasure.app"
  },
  "api": {
    "baseUrl": ["https://biz.aasure.app"],
    "auth": {
      "method": "bearer",
      "name": "Authorization",
      "inputPrefix": "aas_live_"
    }
  },
  "openapi": "https://biz.aasure.app/api/v1/openapi.json",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Core concepts",
            "pages": ["errors", "rate-limits", "idempotency", "pagination", "versioning"]
          },
          {
            "group": "Features",
            "pages": ["features/bookings"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API keys",
            "pages": [
              "api-reference/api-keys/list",
              "api-reference/api-keys/create",
              "api-reference/api-keys/revoke"
            ]
          }
        ]
      }
    ]
  },
  "footerSocials": {
    "website": "https://aasure.app"
  }
}
